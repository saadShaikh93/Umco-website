RewriteEngine On

# Redirect the old umcoca.com domain (and www) to umairmanzoor.com
# Works only if umcoca.com is parked/pointed at this same hosting.
RewriteCond %{HTTP_HOST} ^(www\.)?umcoca\.com$ [NC]
RewriteRule ^(.*)$ https://umairmanzoor.com/$1 [R=301,L]

# Redirect /index.html to the clean root URL
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

ErrorDocument 404 /index.html
